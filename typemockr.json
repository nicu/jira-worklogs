{
  "baseDir": ["src/jira/types.ts"],
  "format": "ts",
  "include": ["src/jira/types.ts"],
  "outDir": "src/mocks",
  "mappings": {
    "*.iconUrl": "'https://api.atlassian.com/ex/jira/7cf1c26d-b821-46a2-8a58-dffa19af32fc/rest/api/2/universal_avatar/view/type/issuetype/avatar/10315?size=medium'",
    "JiraUser.avatarUrls": "{ '32x32': 'https://secure.gravatar.com/avatar/7b982bb0c8ec136f4fe9f5bf8f1171a6?d=https%3A%2F%2Favatar-management--avatars.us-west-2.prod.public.atl-paas.net%2Finitials%2FN-2.png' }",
    "*Status.name": "faker.helpers.arrayElement(['In Progress', 'To Do', 'Done'])",
    "JiraStatusCategory.key": "faker.helpers.arrayElement(['indeterminate', 'new', 'done', 'in-progress'])",
    "JiraIssue.key": "faker.helpers.arrayElement(['PROJ-1', 'PROJ-2', 'PROJ-3'])"
  }
}
